# CSD Solo Miner 配置文件 v5.2.1
# 这是配置文件示例，安装脚本会自动生成实际的 config.yaml

miner:
  wallet_address: "YOUR_WALLET_ADDRESS_HERE"  # 必填：您的CSD钱包地址
  worker_name: "solo-worker-01"               # 工作器名称

mining:
  domain: "compute"                           # 挖矿域
  proposal_interval: 12                        # 提案间隔（秒）
  attestation_interval: 6                      # 认证间隔（秒）
  difficulty_target: "0x00000FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF"

node:
  datadir: "./data"                            # 数据目录
  rpc_host: "0.0.0.0"                         # RPC 监听地址
  rpc_port: 8789                               # RPC 端口
  p2p_host: "0.0.0.0"                         # P2P 监听地址
  p2p_port: 18007                              # P2P 端口
  genesis: "./genesis.bin"                     # 创世文件路径

gpu:
  device_id: 0                                 # GPU 设备编号（0 = 第一块显卡）
  threads_per_block: 256                       # 每块线程数
  max_blocks: 4096                             # 最大块数
  batch_size: 65536                            # 批量大小

bootnodes:
  - "/ip4/35.223.117.16/tcp/30333/p2p/12D3KooWEyoppNCUx8Yx66oV9fJnriXwCcXwDDUA2kj6vnc6iDEp"
  - "/ip4/35.245.161.243/tcp/30333/p2p/12D3KooWHdiAxVd8uMQR1hGWXccidmfCwLqcMpGwR6QcTP6QRMuD"
